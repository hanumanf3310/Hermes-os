#!/usr/bin/env python3
"""
Gemini CLI - สั่งงาน Google Gemini ผ่าน command line
รองรับ: generate, chat, file analysis
"""

import os
import sys
import argparse
from pathlib import Path

# Check for dependencies
try:
    import google.generativeai as genai
except ImportError:
    print("❌ Error: google-generativeai not installed")
    print("   Run: pip install google-generativeai")
    sys.exit(1)

# Configuration
DEFAULT_MODEL = "gemini-pro"
DEFAULT_TEMPERATURE = 0.7

def get_api_key():
    """Get API key from environment"""
    api_key = os.environ.get('GEMINI_API_KEY', '')
    if not api_key:
        print("❌ Error: GEMINI_API_KEY not set")
        print("   export GEMINI_API_KEY='your-key'")
        sys.exit(1)
    return api_key

def configure_genai():
    """Configure Gemini API"""
    api_key = get_api_key()
    genai.configure(api_key=api_key)

def generate_content(prompt: str, model: str = DEFAULT_MODEL, temperature: float = DEFAULT_TEMPERATURE,
                     max_tokens: int = 2048) -> str:
    """Generate content using Gemini"""
    configure_genai()
    
    model_obj = genai.GenerativeModel(model)
    
    response = model_obj.generate_content(
        prompt,
        generation_config=genai.GenerationConfig(
            temperature=temperature,
            max_output_tokens=max_tokens
        )
    )
    
    return response.text

def chat_session(initial_prompt: str = None, model: str = DEFAULT_MODEL) -> None:
    """Start interactive chat session"""
    configure_genai()
    
    model_obj = genai.GenerativeModel(model)
    chat = model_obj.start_chat()
    
    print(f"🤖 Gemini Chat ({model}) - พิมพ์ 'exit' เพื่อออก")
    print("="*60)
    
    if initial_prompt:
        print(f"👤: {initial_prompt}")
        response = chat.send_message(initial_prompt)
        print(f"🤖: {response.text}\n")
    
    while True:
        try:
            user_input = input("👤: ")
            if user_input.lower() in ['exit', 'quit', 'bye']:
                break
            
            response = chat.send_message(user_input)
            print(f"🤖: {response.text}\n")
            
        except KeyboardInterrupt:
            break
        except Exception as e:
            print(f"❌ Error: {e}")
    
    print("\n👋 Goodbye!")

def analyze_file(file_path: str, question: str = None, model: str = DEFAULT_MODEL) -> str:
    """Upload and analyze file"""
    configure_genai()
    
    file_path = Path(file_path)
    if not file_path.exists():
        return f"❌ File not found: {file_path}"
    
    # Read file
    with open(file_path, 'r', encoding='utf-8') as f:
        content = f.read()
    
    # Create prompt
    if question:
        prompt = f"Analyze this file:\n\n{content}\n\nQuestion: {question}"
    else:
        prompt = f"Analyze this file and provide summary:\n\n{content}"
    
    return generate_content(prompt, model)

def main():
    parser = argparse.ArgumentParser(
        description='Gemini CLI - Generate content with Google AI',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  gemini "เขียน Python function สำหรับ fibonacci"
  gemini --file script.py "วิเคราะห์โค้ดนี้"
  gemini --chat
  gemini --model gemini-pro-vision --file image.png "อธิบายรูปนี้"
        """
    )
    
    parser.add_argument('prompt', nargs='?', help='Prompt to send to Gemini')
    parser.add_argument('--file', '-f', help='File to analyze')
    parser.add_argument('--chat', '-c', action='store_true', help='Start chat mode')
    parser.add_argument('--model', '-m', default=DEFAULT_MODEL, 
                       choices=['gemini-pro', 'gemini-pro-vision', 'gemini-ultra'],
                       help=f'Model to use (default: {DEFAULT_MODEL})')
    parser.add_argument('--temperature', '-t', type=float, default=DEFAULT_TEMPERATURE,
                       help=f'Temperature (default: {DEFAULT_TEMPERATURE})')
    parser.add_argument('--max-tokens', type=int, default=2048,
                       help='Max output tokens (default: 2048)')
    parser.add_argument('--configure', action='store_true', help='Setup configuration')
    
    args = parser.parse_args()
    
    # Configuration mode
    if args.configure:
        print("🔧 Gemini CLI Configuration")
        print("="*60)
        print("1. Get API key from: https://makersuite.google.com/app/apikey")
        print("2. Run: export GEMINI_API_KEY='your-key'")
        print("3. Test: gemini 'สวัสดี'")
        return
    
    # Validate inputs
    if not args.prompt and not args.chat and not args.file:
        parser.print_help()
        return
    
    try:
        # Chat mode
        if args.chat:
            chat_session(args.prompt, args.model)
        
        # File analysis mode
        elif args.file:
            result = analyze_file(args.file, args.prompt, args.model)
            print(result)
        
        # Single prompt mode
        elif args.prompt:
            result = generate_content(
                args.prompt,
                args.model,
                args.temperature,
                args.max_tokens
            )
            print(result)
            
    except Exception as e:
        print(f"❌ Error: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == '__main__':
    main()
