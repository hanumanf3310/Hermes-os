#!/usr/bin/env bash
# hermes-os — Hermes OS Master Control
# Usage: hermes-os [on|off|status|dashboard|fleet|policy|rtk]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="$(dirname "$SCRIPT_DIR")"
HERMES_STATE="${HOME}/.hermes/state/hermes-os.json"
CONFIG_FILE="${HOME}/.hermes/config.yaml"

# Colors
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_header() {
    echo -e "${BLUE}🛰️  Hermes OS${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━${NC}"
}

cmd_on() {
    print_header
    local timestamp
    timestamp=$(date -Iseconds)
    
    # Create/update state file
    mkdir -p "$(dirname "$HERMES_STATE")"
    cat > "$HERMES_STATE" <<EOF
{"mode":"hermes_os","timestamp":"$timestamp","rtk_enabled":true}
EOF
    
    echo -e "${GREEN}✓ Hermes OS mode: ON${NC}"
    echo -e "  Mode: hermes_os"
    echo -e "  RTK: enabled"
    echo -e "  UTC+7 policy: active"
    echo -e "  Direct execution: enabled"
    echo -e "  Fleet manual override: enabled"
    echo -e "  Router: retired"
    echo -e "  Control layer: policy + memory + facts + learning + action nerves"
    echo -e "  Execution limbs: thClaws + OMX + Fleet adapters"
    echo ""
    echo -e "${YELLOW}ใช้คำสั่ง 'hermes-os status' เพื่อดูสถานะ${NC}"
}

cmd_off() {
    print_header
    local timestamp
    timestamp=$(date -Iseconds)
    
    # Update state file
    mkdir -p "$(dirname "$HERMES_STATE")"
    cat > "$HERMES_STATE" <<EOF
{"mode":"hermes_off","timestamp":"$timestamp","rtk_enabled":false}
EOF
    
    echo -e "${RED}✗ Hermes OS mode: OFF${NC}"
    echo -e "  Mode: hermes_off"
    echo -e "  Fallback: standard Hermes operation"
    echo ""
    echo -e "${YELLOW}ใช้คำสั่ง 'hermes-os on' เพื่อเปิดใหม่${NC}"
}

cmd_status() {
    python3 - <<'PY'
from pathlib import Path
import importlib.util
import logging
import sys

# Status should render a clean status screen; Hermes OS initialization logs are
# useful for services but noisy in a human-facing launcher command.
logging.disable(logging.CRITICAL)

os_root = Path.home() / ".hermes" / "os"
sys.path.insert(0, str(os_root))

from hermes_os import get_os

# Load the Hermes OS formatter by absolute path.  A separate Hermes Agent
# package named "core" can be present on sys.path in live Gateway/runtime
# environments, so "from core.response_formatter" may resolve to the wrong
# package and break the status command.
formatter_path = os_root / "core" / "response_formatter.py"
spec = importlib.util.spec_from_file_location("hermes_os_response_formatter", formatter_path)
if spec is None or spec.loader is None:
    raise SystemExit(f"Cannot load Hermes OS formatter: {formatter_path}")
module = importlib.util.module_from_spec(spec)
spec.loader.exec_module(module)

print(module.format_os_status(get_os().status()))
PY
}

cmd_dashboard() {
    print_header
    
    local timestamp
    timestamp=$(date "+%Y-%m-%d %H:%M:%S %Z")
    echo "Dashboard | $timestamp"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    
    # System services
    echo -e "${BLUE}Services:${NC}"
    
    # Gateway
    if pgrep -f "hermes_cli.main gateway" > /dev/null 2>&1; then
        local gateway_pid
        gateway_pid=$(pgrep -f "hermes_cli.main gateway" | head -1)
        echo -e "  ${GREEN}●${NC} Gateway (PID: $gateway_pid)"
    else
        echo -e "  ${RED}●${NC} Gateway (stopped)"
    fi
    
    # RTK
    if command -v rtk > /dev/null 2>&1; then
        echo -e "  ${GREEN}●${NC} RTK ($(rtk --version 2>/dev/null || echo 'v?'))"
    else
        echo -e "  ${RED}●${NC} RTK (not found)"
    fi
    
    # Context Mode
    if pgrep -f "context-mode" > /dev/null 2>&1; then
        echo -e "  ${GREEN}●${NC} Context Mode"
    else
        echo -e "  ${YELLOW}●${NC} Context Mode (inactive)"
    fi
    
    # Fleet
    if [[ -d "${HOME}/.hermes/os/fleet" ]]; then
        echo -e "  ${GREEN}●${NC} Fleet Core"
    else
        echo -e "  ${YELLOW}●${NC} Fleet Core (not installed)"
    fi
    
    echo ""
    
    # Resources
    echo -e "${BLUE}Resources:${NC}"
    local mem_usage
    mem_usage=$(free -h 2>/dev/null | awk '/^Mem:/ {print $3 "/" $2}' || echo "N/A")
    echo "  Memory: $mem_usage"
    
    local cpu_load
    cpu_load=$(uptime | awk -F'load average:' '{print $2}' | tr -d ' ' 2>/dev/null || echo "N/A")
    echo "  Load: $cpu_load"
    
    local proc_count
    proc_count=$(pgrep -c "hermes" 2>/dev/null || echo "0")
    echo "  Hermes processes: $proc_count"
    
    echo ""
    
    # Mode status
    echo -e "${BLUE}Hermes OS Mode:${NC}"
    if [[ -f "$HERMES_STATE" ]]; then
        local mode
        mode=$(python3 -c "import json; print(json.load(open('$HERMES_STATE')).get('mode','unknown'))" 2>/dev/null || echo "unknown")
        if [[ "$mode" == "hermes_os" ]]; then
            echo -e "  Status: ${GREEN}● ACTIVE${NC} ($mode)"
        else
            echo -e "  Status: ${YELLOW}● INACTIVE${NC} ($mode)"
        fi
    else
        echo -e "  Status: ${YELLOW}● NOT CONFIGURED${NC}"
    fi
    
    echo ""
    
    # Policy compliance
    echo -e "${BLUE}Policy Compliance:${NC}"
    
    # Read mode from state
    local current_mode="unknown"
    if [[ -f "$HERMES_STATE" ]]; then
        current_mode=$(python3 -c "import json; print(json.load(open('$HERMES_STATE')).get('mode','unknown'))" 2>/dev/null || echo "unknown")
    fi
    
    local tz_policy="❌"
    if [[ -f "$CONFIG_FILE" ]]; then
        if grep -q "timezone: 'Asia/Bangkok'" "$CONFIG_FILE" 2>/dev/null; then
            tz_policy="✅"
        fi
    fi
    echo -e "  ${tz_policy} UTC+7 Timezone"
    
    local rtk_policy="❌"
    if [[ "$current_mode" == "hermes_os" ]]; then
        rtk_policy="✅"
    fi
    echo -e "  ${rtk_policy} RTK Enforcement"
    echo -e "  ✅ Evidence-First Verification"
    echo -e "  ✅ Fleet Auto-Routing"
    
    echo ""
    echo -e "${BLUE}━━ Dashboard ready ━━━━━━━━━━━━━━━━━━━${NC}"
}

cmd_fleet() {
    print_header
    
    echo -e "${BLUE}Fleet Status:${NC}"
    
    if [[ ! -d "${HOME}/.hermes/os/fleet" ]]; then
        echo -e "  ${YELLOW}⚠ Fleet Core ไม่ได้ติดตั้ง${NC}"
        echo "  Path: ~/.hermes/os/fleet/"
        return 1
    fi
    
    echo -e "  ${GREEN}✓${NC} Fleet Core installed"
    
    # Check fleet state
    if [[ -f "$HERMES_STATE" ]]; then
        local fleet_info
        fleet_info=$(python3 -c "
import json
try:
    data = json.load(open('$HERMES_STATE'))
    print(f\"Divisions: {data.get('divisions', 'N/A')}\")
    print(f\"Main Agents: {data.get('main_agents', 'N/A')}\")
    print(f\"Sub Agents: {data.get('sub_agents', 'N/A')}\")
except:
    print('Fleet info not available')
" 2>/dev/null || echo "Fleet info not available")
        echo "  $fleet_info"
    fi
    
    echo ""
    echo "Fleet Agents:"
    echo "  7 Main Agents (Division-01 ถึง Division-07)"
    echo "  21 Sub Agents (3 ต่อ Division)"
    
    echo ""
    echo -e "${GREEN}✓ Fleet พร้อมใช้งาน${NC}"
}

cmd_policy() {
    print_header
    
    echo -e "${BLUE}Active Policy Gates:${NC}"
    echo ""
    
    echo -e "1. ${GREEN}RTK-MES Enforcement${NC}"
    echo "   ทุก terminal command ต้องใช้: rtk run 'command'"
    echo "   Token compression: 60-90%"
    echo ""
    
    echo -e "2. ${GREEN}UTC+7 Timezone Normalization${NC}"
    echo "   งาน date/time-sensitive normalize เป็น Asia/Bangkok ก่อน"
    echo "   ห้าม mix rolling 24h กับ calendar-day"
    echo ""
    
    echo -e "3. ${GREEN}Evidence-First Verification${NC}"
    echo "   ห้าม claim 'สำเร็จ' โดยไม่มีหลักฐาน"
    echo "   ต้องระบุ: exit_code, output, หรือ state change"
    echo ""
    
    echo -e "4. ${GREEN}Fleet Auto-Routing${NC}"
    echo "   Complex task → Fleet อัตโนมัติ"
    echo "   Safety-critical → Fleet + Safety Gate"
    echo ""
    
    echo -e "5. ${GREEN}Checkpoint Gate${NC}"
    echo "   /checkpoint = go/no-go decision"
    echo "   Loop prevention enabled"
    echo ""
    
    # Check current compliance
    echo -e "${BLUE}Current Compliance:${NC}"
    
    local tz_value="not set"
    if [[ -f "$CONFIG_FILE" ]]; then
        tz_value=$(grep "^timezone:" "$CONFIG_FILE" 2>/dev/null | cut -d: -f2 | tr -d " '" || echo "not set")
        if [[ "$tz_value" == "Asia/Bangkok" ]]; then
            echo -e "  ${GREEN}✓${NC} Timezone: $tz_value"
        else
            echo -e "  ${RED}✗${NC} Timezone: $tz_value (expected: Asia/Bangkok)"
        fi
    fi
    
    if command -v rtk > /dev/null 2>&1; then
        echo -e "  ${GREEN}✓${NC} RTK: available"
    else
        echo -e "  ${RED}✗${NC} RTK: not found"
    fi
}

cmd_rtk() {
    print_header
    
    echo -e "${BLUE}RTK Token Compression:${NC}"
    echo ""
    
    if ! command -v rtk > /dev/null 2>&1; then
        echo -e "${RED}✗ RTK ไม่พบใน PATH${NC}"
        echo "  ติดตั้งด้วย: pip install rtk"
        return 1
    fi
    
    local rtk_ver
    rtk_ver=$(rtk --version 2>/dev/null || echo "unknown")
    echo -e "  ${GREEN}✓${NC} RTK found: $rtk_ver"
    echo -e "  ${GREEN}✓${NC} PATH: $(which rtk)"
    
    echo ""
    echo "Usage:"
    echo "  rtk run '<command>'     # Execute with token compression"
    echo "  rtk status             # Check RTK status"
    echo "  rtk gain               # Show token savings"
    
    echo ""
    echo "Examples:"
    echo "  rtk run 'ls -la'"
    echo "  rtk run 'ps aux | grep hermes'"
    echo "  rtk run 'cat ~/.hermes/config.yaml'"
    
    echo ""
    echo -e "${GREEN}✓ RTK พร้อมใช้งาน${NC}"
}

cmd_help() {
    print_header
    echo "Usage: hermes-os [command]"
    echo ""
    echo "Commands:"
    echo "  on         เปิด Hermes OS mode"
    echo "  off        ปิด Hermes OS mode"
    echo "  status     แสดงสถานะระบบ"
    echo "  dashboard  แสดง Dashboard สรุป"
    echo "  fleet      สถานะ Fleet"
    echo "  policy     แสดง Policy ที่ใช้งาน"
    echo "  rtk        สถานะ RTK"
    echo "  help       แสดงความช่วยเหลือนี้"
    echo ""
    echo "Examples:"
    echo "  hermes-os on"
    echo "  hermes-os status"
    echo "  hermes-os dashboard"
}

# Main
main() {
    local cmd="${1:-status}"
    
    case "$cmd" in
        on)
            cmd_on
            ;;
        off)
            cmd_off
            ;;
        status)
            cmd_status
            ;;
        dashboard)
            cmd_dashboard
            ;;
        fleet)
            cmd_fleet
            ;;
        policy)
            cmd_policy
            ;;
        rtk)
            cmd_rtk
            ;;
        help|--help|-h)
            cmd_help
            ;;
        *)
            echo -e "${RED}ไม่รู้จักคำสั่ง: $cmd${NC}"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
