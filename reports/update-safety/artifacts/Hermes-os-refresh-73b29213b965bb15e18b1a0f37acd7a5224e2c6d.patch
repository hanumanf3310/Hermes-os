+    def _handle_hermes_os_command(self, cmd: str):
+        """Handle /hermes-os [on|off|status|dashboard|policy|fleet|rtk] — enter/control Hermes OS mode."""
+        import subprocess
+
+        parts = cmd.strip().split(maxsplit=1)
+        # Root command /hermes_os (or /hermes-os) should activate Hermes OS immediately.
+        subcmd = parts[1].strip().lower() if len(parts) > 1 else "on"
+        valid_cmds = {"on", "off", "status", "dashboard", "policy", "fleet", "rtk"}
+
+        if subcmd not in valid_cmds:
+            _cprint(f"  Usage: /hermes-os [{'|'.join(sorted(valid_cmds))}]")
+            return
+
+        try:
+            result = subprocess.run(
+                ["hermes-os", subcmd],
+                capture_output=True,
+                text=True,
+                timeout=30,
+            )
+            output = (result.stdout or result.stderr or "").strip()
+            from hermes_cli.hermes_os_format import (
+                format_hermes_os_off_message,
+                format_hermes_os_on_message,
+                strip_ansi,
+            )
+
+            clean_output = strip_ansi(output)
+            if result.returncode == 0:
+                if subcmd == "on":
+                    _cprint(f"  {format_hermes_os_on_message(clean_output, chat_scoped=False)}")
+                elif subcmd == "off":
+                    _cprint(f"  {format_hermes_os_off_message(clean_output, chat_scoped=False)}")
+                else:
+                    _cprint(f"  {clean_output or '✅ Done'}")
+            else:
+                _cprint(f"  ❌ Error: {clean_output or 'Command failed'}")
+        except FileNotFoundError:
+            _cprint("  ❌ hermes-os command not found. Is the skill installed?")
+        except subprocess.TimeoutExpired:
+            _cprint("  ⏳ Command timed out after 30s")
+        except Exception as e:
+            _cprint(f"  ❌ Failed: {e}")
+
